      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": " Maya \n Johnson \n",
            "stdout": "mjohnson\n",
            "match": "exact"
          },
          {
            "stdin": " Alex \n Lee \n",
            "stdout": "alee\n",
            "match": "exact"
          }
        ],
        "solutionCode": "first = input().strip()\nlast = input().strip()\nusername = (first[0] + last).lower()\nprint(username)\n"
