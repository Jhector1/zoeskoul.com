      "language": "python",
      "recipe": {
        "type": "template_io",
        "vars": {
          "name": {
            "source": "pick",
            "from": ["Maya", "Jordan", "Alex", "Sam"]
          }
        },
        "tests": [
          {
            "stdinTemplate": "{name}\n",
            "stdoutTemplate": "Hello, {name}!\n",
            "match": "exact"
          }
        ],
        "solutionTemplate": "name = input()\nprint(f\"Hello, {name}!\")\n"
      }
    },
