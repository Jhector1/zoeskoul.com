            "stdout": "zero\n",
            "match": "exact"
          }
        ],
        "solutionCode": "n = int(input())\n\nif n > 0:\n    print(\"positive\")\nelif n < 0:\n    print(\"negative\")\nelse:\n    print(\"zero\")"
      }
