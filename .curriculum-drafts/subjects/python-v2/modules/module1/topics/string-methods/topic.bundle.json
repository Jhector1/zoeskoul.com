      "language": "python",
      "starterCode": "text = 'hello world'\n# Replace 'hello' with 'hi'",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "12\n",
            "stdout": "hi world",
            "match": "exact"
