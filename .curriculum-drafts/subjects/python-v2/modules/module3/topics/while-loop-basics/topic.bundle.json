      "starterCode": "n = 1\n# TODO: use a while loop to print 1 to 5",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "",
            "stdout": "1\n2\n3\n4\n5\n",
            "match": "exact"
          },
          {
            "stdin": "",
            "stdout": "1\n2\n3\n4\n5\n",
            "match": "exact"
          }
        ],
        "solutionCode": "n = 1\nwhile n <= 5:\n    print(n)\n    n = n + 1"
      }
    },
