          }
        ],
        "solutionCode": "def divide_by_number(number):\n    if number == 0:\n        return 'Cannot divide by zero!'\n    else:\n        return 10 / number\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nnumber = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(divide_by_number(number))"
      }
