      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "3\n4\n+\n",
            "stdout": "7\n",
            "match": "exact"
          },
          {
            "stdin": "10\n2\n/\n",
            "stdout": "5.0\n",
            "match": "exact"
