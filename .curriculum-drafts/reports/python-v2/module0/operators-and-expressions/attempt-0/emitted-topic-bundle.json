        "language": "python",
        "entryFilePath": "main.py",
        "starterCode": "num1 = int(input())\nnum2 = int(input())\nresult = num1 > num2\n\n# Read two numbers and an operator from input\nnum1 = int(input())\nnum2 = int(input())\noperator = input().strip()\n\n# Perform the operation\n# Print the result",
        "starterFiles": [
          {
            "path": "main.py",
            "content": "num1 = int(input())\nnum2 = int(input())\nresult = num1 > num2\n\n# Read two numbers and an operator from input\nnum1 = int(input())\nnum2 = int(input())\noperator = input().strip()\n\n# Perform the operation\n# Print the result",
            "language": "python",
            "isEntry": true,
            "entry": true
          }
        ]
