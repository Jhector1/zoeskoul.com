      "recipe": {
        "type": "sql_query",
        "datasetId": "school_relations_intro",
        "resultShape": "table",
        "solutionCode": "SELECT d.name AS department_name, COUNT(c.id) AS course_count, COUNT(e.id) AS enrollment_count, COUNT(DISTINCT e.student_id) AS student_count,\nCASE\n  WHEN COUNT(e.id) = 0 THEN 'No activity'\n  WHEN COUNT(c.id) >= 2 AND COUNT(DISTINCT e.student_id) >= 2 THEN 'Broad participation'\n  ELSE 'Active'\nEND AS participation_status\nFROM departments d\nLEFT JOIN courses c ON d.id = c.department_id\nLEFT JOIN enrollments e ON c.id = e.course_id\nGROUP BY d.id\nORDER BY enrollment_count DESC, department_name ASC;"
      }
