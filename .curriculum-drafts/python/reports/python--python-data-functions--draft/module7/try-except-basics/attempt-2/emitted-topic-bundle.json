            "match": "exact",
            "files": [
              {
                "path": "values.txt",
                "content": "5\nx\n10\n3"
              }
            ]
          },
          {
            "stdout": "Total: 7\n",
            "match": "exact",
            "files": [
              {
                "path": "values.txt",
                "content": "2\nbad\n-1\n6\nskip"
