        ],
        "solutionCode": "text = input()\n\nwith open(\"number.txt\") as file:\n    text = file.read().strip()\n\ntry:\n    number = int(text)\n    print(f\"Number: {number}\")\nexcept ValueError:\n    print(\"Invalid number\")"
