# Image source
# The workflow builds:
#   ghcr.io/$GHCR_OWNER/zoeskoul-runner:$IMAGE_TAG
#   ghcr.io/$GHCR_OWNER/zoeskoul-runtime:$IMAGE_TAG
GHCR_OWNER=your-github-user-or-org-lowercase
IMAGE_TAG=prod
CADDY_IMAGE=caddy:2-alpine
JUDGE0_IMAGE=judge0/judge0:1.13.1
JUDGE0_POSTGRES_IMAGE=postgres:16-alpine
JUDGE0_REDIS_IMAGE=redis:7-alpine

# Public domains. Both DNS records point to this runner VM public IP.
CADDY_EMAIL=admin@zoeskoul.com
RUNNER_DOMAIN=runner.zoeskoul.com
JUDGE0_DOMAIN=judge0.zoeskoul.com

NODE_ENV=production
PORT=4001

# Must match Vercel env.
RUNNER_SECRET=CHANGE_ME_SAME_AS_VERCEL
RUNNER_SHARED_SECRET=CHANGE_ME_SAME_AS_VERCEL
RUNNER_EDGE_SECRET=CHANGE_ME_LONG_RANDOM_IF_USED

# Must match Vercel env.
PTY_ATTACH_SECRET=CHANGE_ME_SAME_AS_VERCEL_ATTACH_SECRET
RUNNER_ATTACH_TOKEN_SECRET=CHANGE_ME_SAME_AS_VERCEL_ATTACH_SECRET
PTY_ATTACH_TOKEN_TTL_SECONDS=60
RUNNER_ATTACH_TOKEN_TTL_SECONDS=60
PTY_ATTACH_REPLAY_TTL_MS=300000

RUNNER_ALLOWED_ORIGINS=https://zoeskoul.com,https://www.zoeskoul.com
RUNNER_CORS_ORIGIN=https://zoeskoul.com
ALLOWED_WEB_ORIGINS=https://zoeskoul.com,https://www.zoeskoul.com
WEB_URL=https://zoeskoul.com

RUNNER_SESSION_TTL_MS=1800000
RUNNER_WORKSPACE_TTL_MS=600000
RUN_WALL_TIMEOUT_MS=15000
RUN_IDLE_TIMEOUT_MS=20000

RUNNER_MAX_CONCURRENT_PER_ACTOR=2
RUNNER_MAX_CONCURRENT_GLOBAL=20
RUNNER_STARTS_PER_MINUTE_PER_ACTOR=5

RUNNER_MAX_FILES=32
RUNNER_MAX_TOTAL_BYTES=262144
RUNNER_MAX_FILE_BYTES=65536
RUNNER_MAX_ENTRIES=200
RUNNER_MIN_FREE_BYTES=2147483648
RUNNER_MAX_WORKSPACE_ROOT_BYTES=10737418240

RUNNER_MEMORY_LIMIT_MB=128
RUNNER_CPU_QUOTA=50000
RUNNER_PIDS_LIMIT=128
RUNNER_CHILD_NETWORK=none
RUNNER_DISABLE_NETWORK=true

RUNNER_SERVICE_MEM_LIMIT=512m
RUNNER_SERVICE_CPUS=1.0
RUNNER_CONTAINER_USER=1000:1000

# Rootless Docker socket. Install with zoe-infra/scripts/install-rootless-docker.sh.
RUNNER_DOCKER_SOCKET_HOST=/run/user/1000/docker.sock
RUNNER_DOCKER_SOCKET_IN_CONTAINER=/docker.sock

# Judge0 is internal to Docker, but public HTTPS access is through Caddy on judge0.zoeskoul.com.
JUDGE0_URL=http://judge0:2358
JUDGE0_AUTHN_HEADER=X-Judge0-Token
JUDGE0_AUTHN_TOKEN=CHANGE_ME_LONG_RANDOM
JUDGE0_AUTHZ_HEADER=X-Judge0-Admin
JUDGE0_AUTHZ_TOKEN=CHANGE_ME_LONG_RANDOM
JUDGE0_POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
JUDGE0_REDIS_PASSWORD=CHANGE_ME_LONG_RANDOM
JUDGE0_ALLOW_ORIGIN=

JUDGE0_ENABLE_WAIT_RESULT=true
JUDGE0_DISABLE_MEMORY_LIMIT=false
JUDGE0_ENABLE_COMPILER_OPTIONS=false
JUDGE0_ENABLE_COMMAND_LINE_ARGUMENTS=false
JUDGE0_ENABLE_SUBMISSION_DELETE=false
JUDGE0_ENABLE_BATCHED_SUBMISSIONS=false
JUDGE0_ENABLE_CALLBACKS=false
JUDGE0_MAX_QUEUE_SIZE=50
JUDGE0_CPU_TIME_LIMIT=2
JUDGE0_MAX_CPU_TIME_LIMIT=5
JUDGE0_WALL_TIME_LIMIT=5
JUDGE0_MAX_WALL_TIME_LIMIT=10
JUDGE0_MEMORY_LIMIT=128000
JUDGE0_MAX_MEMORY_LIMIT=256000
JUDGE0_STACK_LIMIT=64000
JUDGE0_MAX_STACK_LIMIT=128000
JUDGE0_MAX_FILE_SIZE=1024
JUDGE0_MAX_PROCESSES_AND_OR_THREADS=64
JUDGE0_API_MEM_LIMIT=2g
JUDGE0_WORKER_MEM_LIMIT=3g
JUDGE0_API_CPUS=2.0
JUDGE0_WORKER_CPUS=2.0

# Interactive terminal lessons can legitimately start many short clean PTYs while navigating.
SESSION_STARTS_PER_MINUTE=60
MAX_SESSION_STARTS_PER_MINUTE=60
PTY_SESSION_STARTS_PER_MINUTE=60
