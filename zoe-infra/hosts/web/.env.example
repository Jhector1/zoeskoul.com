# Image source
GHCR_OWNER=your-github-user-or-org-lowercase
IMAGE_TAG=prod
CADDY_IMAGE=caddy:2-alpine
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# Public domains. All three DNS records point to VM 1 public IP.
DOMAIN=zoeskoul.com
RUNNER_DOMAIN=runner.zoeskoul.com
CADDY_EMAIL=admin@zoeskoul.com

# VM 2 private runner URL over Hetzner private network.
RUNNER_PRIVATE_URL=http://10.10.0.3:4001

# App database/cache
POSTGRES_DB=zoeskoul
POSTGRES_USER=zoeskoul
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM
REDIS_PASSWORD=CHANGE_ME_LONG_RANDOM
DATABASE_URL=postgresql://zoeskoul:CHANGE_ME_LONG_RANDOM@postgres:5432/zoeskoul?schema=public
REDIS_URL=redis://:CHANGE_ME_LONG_RANDOM@redis:6379

# Next/Auth
NODE_ENV=production
NEXTAUTH_URL=https://zoeskoul.com
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM
AUTH_SECRET=CHANGE_ME_LONG_RANDOM

# Runner integration.
# RUNNER_BASE_URL is server-to-server private HTTP.
# RUNNER_WS_BASE_URL is browser WebSocket URL through Caddy.
RUNNER_BASE_URL=http://10.10.0.3:4001
RUNNER_WS_BASE_URL=wss://runner.zoeskoul.com

# Keep both names until your codebase is fully normalized.
RUNNER_SECRET=CHANGE_ME_SAME_AS_VM2
RUNNER_SHARED_SECRET=CHANGE_ME_SAME_AS_VM2
RUNNER_EDGE_SECRET=CHANGE_ME_LONG_RANDOM_IF_USED

# Keep both names until your codebase is fully normalized.
PTY_ATTACH_SECRET=CHANGE_ME_SAME_AS_VM2_ATTACH_SECRET
RUNNER_ATTACH_TOKEN_SECRET=CHANGE_ME_SAME_AS_VM2_ATTACH_SECRET
PTY_ATTACH_TOKEN_TTL_SECONDS=60
RUNNER_ATTACH_TOKEN_TTL_SECONDS=60

# Optional Judge0 URL if web calls Judge0 directly.
# Recommended: web should use runner for execution and not talk to Judge0 directly.
JUDGE0_URL=http://10.10.0.3:2358
JUDGE0_AUTHN_HEADER=X-Judge0-Token
JUDGE0_AUTHN_TOKEN=CHANGE_ME_SAME_AS_VM2_JUDGE0_TOKEN

WEB_MEM_LIMIT=1536m
WEB_CPUS=1.5
