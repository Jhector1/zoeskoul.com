# Vercel Project Settings -> Environment Variables
# Web app runs on Vercel. Runner and Judge0 live on the Hetzner runner VM behind Caddy.

NODE_ENV=production
NEXTAUTH_URL=https://zoeskoul.com
NEXTAUTH_SECRET=CHANGE_ME_LONG_RANDOM
AUTH_SECRET=CHANGE_ME_LONG_RANDOM

# Use managed Postgres/Redis for Vercel, e.g. Neon/Supabase + Upstash.
DATABASE_URL=CHANGE_ME_MANAGED_POSTGRES_URL
REDIS_URL=CHANGE_ME_MANAGED_REDIS_URL

RUNNER_BASE_URL=https://runner.zoeskoul.com
RUNNER_WS_BASE_URL=wss://runner.zoeskoul.com
RUNNER_SECRET=CHANGE_ME_SAME_AS_RUNNER_VM
RUNNER_SHARED_SECRET=CHANGE_ME_SAME_AS_RUNNER_VM
PTY_ATTACH_SECRET=CHANGE_ME_SAME_AS_RUNNER_VM_ATTACH_SECRET
RUNNER_ATTACH_TOKEN_SECRET=CHANGE_ME_SAME_AS_RUNNER_VM_ATTACH_SECRET

JUDGE0_URL=https://judge0.zoeskoul.com
JUDGE0_AUTHN_HEADER=X-Judge0-Token
JUDGE0_AUTHN_TOKEN=CHANGE_ME_SAME_AS_RUNNER_VM_JUDGE0_AUTHN_TOKEN
