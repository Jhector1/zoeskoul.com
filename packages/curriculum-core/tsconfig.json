{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",

    "composite": true,
    "declaration": true,
    "declarationMap": true,

    "noEmit": false,
    "emitDeclarationOnly": false,

    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "types": ["node"]

  },
  "include": ["src/**/*.ts"]
}