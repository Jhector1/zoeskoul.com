{
  "name": "@zoeskoul/curriculum-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./sql": {
      "types": "./dist/sql/index.d.ts",
      "default": "./dist/sql/index.js"
    },
    "./review": {
      "types": "./dist/review/index.d.ts",
      "default": "./dist/review/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "pretest": "pnpm --filter @zoeskoul/curriculum-core build && pnpm --filter @zoeskoul/curriculum-contracts build",
    "test": "vitest run --root ../.. packages/curriculum-runtime/src"
  },
  "dependencies": {
    "@zoeskoul/curriculum-contracts": "workspace:*",
    "@zoeskoul/curriculum-core": "workspace:*",
    "@zoeskoul/practice-checks": "workspace:*",
    "jszip": "^3.10.1"
  }
}