import {
  applyResolvedAiEnv,
  resolveGenerationProviderModel,
} from "./selectProviderModel.js";

/**
 * Backward-compatible wrapper for old compile/translate callers.
 * It is no longer OpenAI-only: when no --provider flag/env exists, it asks for
 * provider first, then displays that provider's model list.
 */
export async function selectModelFromConsole() {
  const resolved = await resolveGenerationProviderModel({
    cliArgs: process.argv.slice(2),
    interactive: true,
  });

  applyResolvedAiEnv(resolved);

  console.log(`Selected AI provider: ${resolved.provider}`);
  console.log(`Selected model: ${resolved.model}`);
  console.log("");

  return resolved.model;
}
