{
  "policyId": "python-for-beginners-validation",
  "allowedConcepts": [
    "print",
    "comments",
    "values",
    "expressions",
    "variables",
    "input",
    "strings",
    "conditionals",
    "for loops",
    "while loops"
  ],
  "disallowedConcepts": [
    "imports",
    "files",
    "classes",
    "multi-file projects"
  ],
  "validationRequirements": {
    "goldenTestsRequired": true,
    "preferSmallPrograms": true
  }
}
