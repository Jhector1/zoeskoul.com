{
  "policyId": "python-data-functions-validation",
  "allowedConcepts": [
    "functions",
    "parameters",
    "return values",
    "lists",
    "tuples",
    "dictionaries",
    "nested data structures",
    "imports",
    "modules",
    "helper files",
    "standard library csv",
    "file input",
    "file output",
    "file creation with write mode",
    "relative paths",
    "exceptions",
    "try except",
    "data cleaning",
    "simple csv processing"
  ],
  "disallowedConcepts": [
    "classes",
    "external packages",
    "advanced multi-file applications",
    "absolute paths",
    "manual workspace file creation without validation"
  ],
  "validationRequirements": {
    "goldenTestsRequired": true,
    "requireFunctionFocusedChecks": true,
    "requireSemanticForFunctionReturnExercises": true,
    "requireFixedTestsForFileIoExercises": true,
    "requireExplicitImportTopicBeforeCsv": true
  }
}
