    "EXCEPT",
    "INSERT",
    "UPDATE",
    "DELETE",
    "CREATE TABLE",
    "ALTER TABLE",
    "DROP TABLE"
  ],
  "datasets": [
    "school_relations_intro"
  ],
  "validationRequirements": {
    "goldenTestsRequired": true,
    "requireMappedImages": true,
    "requireResolvedI18n": true,
    "requireTryItPrefix": true,
    "requireTryItOnAllTechnicalSketches": true,
    "requireQuizNoCodeInput": true,
    "requireExactlyOneModuleProjectPerStandardModule": true,
    "requireFinalCapstone": true,
    "requireCapstoneRubric": true,
    "requireProjectStepChaining": true,
    "requireJoinRelationshipMetadata": true,
    "requireErdOrTableRelationshipVisuals": true,
    "requireJoinConditionForEveryJoin": true,
    "requireDuplicateRowTeachingChecks": true,
    "requireQualifiedColumnsInMultiTableQueries": true,
    "requireNonEmptySqlResults": true,
    "allowIntentionalEmptyOnlyWhenDeclared": true,
    "requireUniqueLearnerPrompts": true,
    "requireNoGenericRepairText": true,
    "forbidStandalonePrerequisiteReviewTopics": true
  },
  "projectRequirements": {
    "standardModuleProjectCount": 3,
    "capstoneCount": 1,
    "standardProjectStepTargets": {
      "module-0-student-enrollment-roster": 5,
      "module-1-course-enrollment-directory": 5,
      "module-2-department-participation-scorecard": 6
    },
    "capstoneStepTarget": 4,
    "flow": "progressive"
  },
  "relationshipRequirements": {
    "datasetId": "school_relations_intro",
    "relationships": [
      {
        "fromTable": "courses",
        "fromColumn": "department_id",
        "toTable": "departments",
        "toColumn": "id",
        "cardinality": "many-to-one"
      },
      {
        "fromTable": "enrollments",
        "fromColumn": "student_id",
        "toTable": "students",
        "toColumn": "id",
        "cardinality": "many-to-one"
      },
      {
        "fromTable": "enrollments",
        "fromColumn": "course_id",
        "toTable": "courses",
        "toColumn": "id",
        "cardinality": "many-to-one"
      }
    ],
    "requireDeclaredRelationshipForEverySolutionJoin": true,
    "requireErdOrTableRelationshipVisuals": true
  },
  "repetitionGuard": {
    "forbidStandaloneTopicConcepts": [
      "SELECT basics",
      "WHERE basics",
      "ORDER BY basics",
      "aliases basics",
      "NULL basics",
      "aggregate function basics",
      "GROUP BY basics",
      "HAVING basics",
      "CASE basics"
    ],
    "forbidSubqueries": true,
    "requireDistinctExampleTryItProjectQuestions": true,
    "maxStandardModules": 3,
    "reason": "The course is intentionally focused on relational joins; splitting prerequisite concepts into review modules would recreate content already completed in the first two SQL courses."
  }
}
