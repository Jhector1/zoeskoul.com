    "BETWEEN",
    "IS NULL",
    "IS NOT NULL",
    "AS",
    "DISTINCT",
    "arithmetic expressions",
    "parentheses",
    "ROUND",
    "COALESCE",
    "CASE",
    "COUNT",
    "SUM",
    "AVG",
    "MIN",
    "MAX",
    "GROUP BY",
    "HAVING",
    "conditional aggregation",
    "report grain",
    "deterministic sorting",
