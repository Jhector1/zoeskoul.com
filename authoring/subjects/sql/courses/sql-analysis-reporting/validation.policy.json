{
  "policyId": "sql-analysis-reporting-validation",
  "allowedConcepts": [
    "SELECT",
    "FROM",
    "WHERE",
    "comparison_operators",
    "AND",
    "OR",
    "NOT",
    "ORDER BY",
    "ASC",
    "DESC",
    "LIMIT",
    "LIKE",
    "IN",
    "NOT IN",
    "BETWEEN",
    "IS NULL",
    "IS NOT NULL",
    "AS",
    "DISTINCT",
    "arithmetic expressions",
    "parentheses",
    "ROUND",
    "COALESCE",
    "CASE",
    "COUNT",
    "SUM",
    "AVG",
    "MIN",
    "MAX",
    "GROUP BY",
    "HAVING",
    "conditional aggregation",
    "report grain",
    "deterministic sorting"
  ],
  "disallowedConcepts": [
    "JOIN",
    "INNER JOIN",
    "LEFT JOIN",
    "RIGHT JOIN",
    "FULL JOIN",
    "CROSS JOIN",
    "subquery",
    "CTE",
    "WITH",
    "window functions",
    "OVER",
    "PARTITION BY",
    "INSERT",
    "UPDATE",
    "DELETE",
    "CREATE TABLE",
    "ALTER TABLE",
    "DROP TABLE"
  ],
  "datasets": [
    "sales_reporting"
  ],
  "validationRequirements": {
    "goldenTestsRequired": true,
    "requireOrderStableExpectedRows": true,
    "requireExactExpectedColumns": true,
    "requireAggregateExpectedResults": true,
    "requireTryItOnAllTechnicalSketches": true,
    "requireQuizNoCodeInput": true,
    "requireExactlyOneModuleProjectPerStandardModule": true,
    "requireFinalCapstone": true,
    "requireProjectStepChaining": true,
    "requireSingleTableQueries": true,
    "requireNonEmptySqlResults": true,
    "requireUniqueLearnerPrompts": true,
    "requireNoGenericRepairText": true
  },
  "projectRequirements": {
    "standardModuleProjectCount": 5,
    "capstoneCount": 1,
    "standardProjectStepTargets": {
      "module-0-order-value-detail-report": 5,
      "module-1-discount-audit-report": 6,
      "module-2-storewide-kpi-snapshot": 6,
      "module-3-region-category-scorecard": 6,
      "module-4-performance-exception-report": 7
    },
    "capstoneStepTarget": 8,
    "flow": "progressive"
  }
}
