        "solutionCode": "import csv\n\nwith open(\"scores.csv\", \"r\") as file:\n    reader = csv.DictReader(file)\n    for row in reader:\n        name = row[\"name\"].strip()\n        try:\n            score = int(row[\"score\"].strip())\n            print(f\"{name}: {score}\")\n        except ValueError:\n            print(f\"Skipped: {name}\")"
