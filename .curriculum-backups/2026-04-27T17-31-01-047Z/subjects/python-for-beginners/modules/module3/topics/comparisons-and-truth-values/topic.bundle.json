      "messageBase": "topics.python-for-beginners.python-3.comparisons-and-truth-values.quiz.truthiness-check",
      "language": "python",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "0\n",
            "stdout": "Value is falsy\n",
            "match": "exact"
          },
          {
            "stdin": "'Hello'\n",
            "stdout": "Value is truthy\n",
            "match": "exact"
          },
          {
            "stdin": "''\n",
            "stdout": "Value is falsy\n",
            "match": "exact"
          }
        ],
        "solutionCode": "import ast\n\nraw = input()\ntry:\n    value = ast.literal_eval(raw)\nexcept Exception:\n    value = raw\n\nif value:\n    print('Value is truthy')\nelse:\n    print('Value is falsy')\n"
      }
    }
