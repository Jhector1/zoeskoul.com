    {
      "id": "code-break-stop-at-number",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.break-and-continue.quiz.code-break-stop-at-number",
      "language": "python",
      "starterCode": "while True:\n    # TODO: read a number\n    # TODO: stop when the number is 0\n    # TODO: print the number if it is not 0\n    pass",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "4\n7\n0\n",
            "stdout": "4\n7\n",
            "match": "exact"
          }
        ],
        "solutionCode": "while True:\n    number = int(input())\n    if number == 0:\n        break\n    print(number)"
      }
    },
    {
      "id": "code-continue-skip-multiples",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.break-and-continue.quiz.code-continue-skip-multiples",
      "language": "python",
      "starterCode": "for number in range(1, 11):\n    # TODO: if number is a multiple of 3, skip it\n    # TODO: otherwise print it\n    pass",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "",
            "stdout": "1\n2\n4\n5\n7\n8\n10\n",
            "match": "exact"
          }
        ],
        "solutionCode": "for number in range(1, 11):\n    if number % 3 == 0:\n        continue\n    print(number)"
      }
    },
    {
      "id": "code-break-first-negative",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.break-and-continue.quiz.code-break-first-negative",
      "language": "python",
      "starterCode": "total = 0\n\nwhile True:\n    # TODO: read a number\n    # TODO: stop if it is negative\n    # TODO: otherwise add it to total\n    pass\n\nprint(total)",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "5\n8\n2\n-1\n",
            "stdout": "15\n",
            "match": "exact"
          },
          {
            "stdin": "-3\n",
            "stdout": "0\n",
            "match": "exact"
          }
        ],
        "solutionCode": "total = 0\n\nwhile True:\n    number = int(input())\n    if number < 0:\n        break\n    total += number\n\nprint(total)"
      }
    },
    {
      "id": "code-continue-skip-letter",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.break-and-continue.quiz.code-continue-skip-letter",
      "language": "python",
      "starterCode": "word = \"banana\"\n\nfor ch in word:\n    # TODO: skip the letter a\n    # TODO: print the other characters\n    pass",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "",
            "stdout": "b\nn\nn\n",
            "match": "exact"
          }
        ],
        "solutionCode": "word = \"banana\"\n\nfor ch in word:\n    if ch == \"a\":\n        continue\n    print(ch)"
      }
    },
    {
      "id": "code-break-guess-game",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.break-and-continue.quiz.code-break-guess-game",
      "language": "python",
      "starterCode": "while True:\n    guess = int(input())\n    # TODO: if the guess is 7, print the success message and stop\n    # TODO: otherwise print the retry message",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "3\n5\n7\n",
            "stdout": "try again\ntry again\ncorrect\n",
            "match": "exact"
          },
          {
            "stdin": "7\n",
            "stdout": "correct\n",
            "match": "exact"
          }
        ],
        "solutionCode": "while True:\n    guess = int(input())\n    if guess == 7:\n        print(\"correct\")\n        break\n    print(\"try again\")"
      }
    }
