      "recipe": {
        "type": "sql_query",
        "datasetId": "sales_kpi",
        "resultShape": "table",
        "solutionCode": "SELECT category, SUM(quantity) AS total_quantity\nFROM sales_reporting\nWHERE order_status = 'Completed' AND region = 'North'\nGROUP BY category\nHAVING total_quantity > 10;"
      }
