{
  "policyId": "sql-analysis-reporting-validation",
  "allowedConcepts": [
    "SELECT",
    "FROM",
    "WHERE",
    "comparison_operators",
    "AND",
    "OR",
    "NOT",
    "ORDER BY",
    "ASC",
    "DESC",
    "LIMIT",
    "LIKE",
    "IN",
    "NOT IN",
    "BETWEEN",
    "IS NULL",
    "IS NOT NULL",
    "AS",
    "DISTINCT",
    "arithmetic expressions",
    "parentheses",
    "ROUND",
    "COALESCE",
    "CASE",
    "COUNT",
    "SUM",
    "AVG",
    "MIN",
    "MAX",
    "GROUP BY",
    "HAVING",
    "conditional aggregation",
    "report grain",
    "deterministic sorting"
  ],
  "disallowedConcepts": [
    "JOIN",
    "INNER JOIN",
    "LEFT JOIN",
    "RIGHT JOIN",
    "FULL JOIN",
    "CROSS JOIN",
    "subquery",
    "CTE",
    "WITH",
    "window functions",
    "OVER",
    "PARTITION BY",
    "INSERT",
    "UPDATE",
    "DELETE",
    "CREATE TABLE",
    "ALTER TABLE",
    "DROP TABLE"
  ],
  "datasets": [
    "sales_kpi"
  ],
  "validationRequirements": {
    "goldenTestsRequired": true,
    "requireOrderStableExpectedRows": true,
    "requireExactExpectedColumns": true,
    "requireAggregateExpectedResults": true,
    "requireTryItOnAllTechnicalSketches": true,
    "requireQuizNoCodeInput": true,
    "requireExactlyOneModuleProjectPerStandardModule": true,
    "requireFinalCapstone": true,
    "requireProjectStepChaining": true,
    "requireSingleTableQueries": true
  },
  "projectRequirements": {
    "standardModuleProjectCount": 5,
    "capstoneCount": 1,
    "standardProjectStepTarget": "5-7",
    "capstoneStepTarget": 8,
    "flow": "progressive"
  },
  "sourceTable": "sales_reporting",
  "notes": [
    "Use only the sales_reporting table from the sales_kpi dataset for lessons, Try It exercises, module projects, and the capstone.",
    "Do not switch to the legacy orders table in this course."
  ]
}
