      "recipe": {
        "type": "sql_query",
        "datasetId": "sales_kpi",
        "resultShape": "table",
        "solutionCode": "SELECT sales_rep,\n       SUM(quantity * unit_price) AS total_sales,\n       CASE\n           WHEN SUM(quantity * unit_price) > 1500 THEN 'Excellent'\n           WHEN SUM(quantity * unit_price) BETWEEN 1000 AND 1500 THEN 'Good'\n           ELSE 'Needs Improvement'\n       END AS performance_band\nFROM sales_reporting\nGROUP BY sales_rep;"
      }
    },
