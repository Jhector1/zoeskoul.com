    {
      "id": "code-skip-multiples-of-three",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-3.break-and-continue.quiz.code-skip-multiples-of-three",
      "language": "python",
      "starterCode": "n = int(input())\n\n# Print numbers from 1 to n.\n# Skip multiples of 3 using continue.",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "7\n",
            "stdout": "1\n2\n4\n5\n7\n",
            "match": "exact"
          },
          {
            "stdin": "3\n",
            "stdout": "1\n2\n",
            "match": "exact"
          }
        ],
        "solutionCode": "n = int(input())\ncount = 0\n\nwhile count < n:\n    count += 1\n    if count % 3 == 0:\n        continue\n    print(count)"
      }
    },
    {
      "id": "code-stop-at-negative",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-3.break-and-continue.quiz.code-stop-at-negative",
      "language": "python",
      "starterCode": "# Read integers one per line.\n# Stop when a negative number appears.\n# Print the total of the non-negative numbers.",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "4\n6\n0\n-1\n",
            "stdout": "10\n",
            "match": "exact"
          },
          {
            "stdin": "5\n2\n3\n-9\n",
            "stdout": "10\n",
            "match": "exact"
          }
        ],
        "solutionCode": "total = 0\n\nwhile True:\n    num = int(input())\n    if num < 0:\n        break\n    total += num\n\nprint(total)"
      }
    }
  ]
