      "starterCode": "def extract_substring(s, start, end):\n    # Your code here\n    pass\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\ns = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\nstart = _parse_arg(_inputs[1]) if len(_inputs) > 1 else \"\"\nend = _parse_arg(_inputs[2]) if len(_inputs) > 2 else \"\"\n\nprint(extract_substring(s, start, end))",
