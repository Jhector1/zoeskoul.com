      "starterCode": "def is_leap_year(year):\n    # Your code here\n    pass\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nyear = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(is_leap_year(year))",
