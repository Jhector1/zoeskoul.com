      "starterCode": "def join_words(words):\n    # Your code here\n    pass\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nwords = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(join_words(words))",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "['Hello', 'world']",
            "stdout": "Hello world",
            "match": "exact"
          },
          {
            "stdin": "['Python', 'is', 'fun']",
            "stdout": "Python is fun",
            "match": "exact"
          }
        ],
        "solutionCode": "def join_words(words):\n    return ' '.join(words)\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nwords = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(join_words(words))"
      }
    },
