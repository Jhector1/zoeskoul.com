        "solutionCode": "def replace_word(text):\n    return text.replace('cat', 'dog')\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\ntext = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(replace_word(text))"
