      "starterCode": "text = input()\n# Split the text into words and print them joined with hyphens",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "red blue green\n",
            "stdout": "red-blue-green\n",
            "match": "exact"
          },
          {
            "stdin": "one two\n",
            "stdout": "one-two\n",
            "match": "exact"
          }
        ],
        "solutionCode": "text = input()\nwords = text.split(\" \")\nresult = \"-\".join(words)\nprint(result)"
