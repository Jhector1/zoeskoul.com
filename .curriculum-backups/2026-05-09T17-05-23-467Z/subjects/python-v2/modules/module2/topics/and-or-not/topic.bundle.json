      "id": "code-eligibility-check",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-2.and-or-not.quiz.code-eligibility-check",
      "language": "python",
      "starterCode": "age = int(input())\nhas_ticket = input().strip()\n\n# Write your code below",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "15\nyes\n",
            "stdout": "eligible\n",
            "match": "exact"
          },
          {
            "stdin": "12\nyes\n",
            "stdout": "not eligible\n",
            "match": "exact"
          },
          {
            "stdin": "16\nno\n",
            "stdout": "not eligible\n",
            "match": "exact"
          }
        ],
        "solutionCode": "age = int(input())\nhas_ticket = input().strip()\n\nif age >= 13 and has_ticket == \"yes\":\n    print(\"eligible\")\nelse:\n    print(\"not eligible\")"
      }
    },
    {
      "id": "code-weekend-or-holiday",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-2.and-or-not.quiz.code-weekend-or-holiday",
      "language": "python",
      "starterCode": "is_weekend_text = input().strip()\nis_holiday_text = input().strip()\n\n# Convert the inputs and print the result",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "true\nfalse\n",
            "stdout": "day off\n",
            "match": "exact"
          },
          {
            "stdin": "false\ntrue\n",
            "stdout": "day off\n",
            "match": "exact"
          },
          {
            "stdin": "false\nfalse\n",
            "stdout": "work day\n",
            "match": "exact"
          }
        ],
        "solutionCode": "is_weekend_text = input().strip()\nis_holiday_text = input().strip()\n\nis_weekend = is_weekend_text == \"true\"\nis_holiday = is_holiday_text == \"true\"\n\nif is_weekend or is_holiday:\n    print(\"day off\")\nelse:\n    print(\"work day\")"
      }
    },
    {
      "id": "code-login-not-banned",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-2.and-or-not.quiz.code-login-not-banned",
      "language": "python",
      "starterCode": "is_logged_in_text = input().strip()\nis_banned_text = input().strip()\n\n# Write your condition and print the result",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "true\nfalse\n",
            "stdout": "access granted\n",
            "match": "exact"
          },
          {
            "stdin": "true\ntrue\n",
            "stdout": "access denied\n",
            "match": "exact"
          },
          {
            "stdin": "false\nfalse\n",
            "stdout": "access denied\n",
            "match": "exact"
          }
        ],
        "solutionCode": "is_logged_in_text = input().strip()\nis_banned_text = input().strip()\n\nis_logged_in = is_logged_in_text == \"true\"\nis_banned = is_banned_text == \"true\"\n\nif is_logged_in and not is_banned:\n    print(\"access granted\")\nelse:\n    print(\"access denied\")"
      }
    }
