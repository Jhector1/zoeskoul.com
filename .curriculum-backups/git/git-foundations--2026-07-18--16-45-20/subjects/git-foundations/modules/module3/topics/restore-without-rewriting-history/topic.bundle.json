          {
            "pattern": "git\\s+reset\\s+--hard|git\\s+push\\s+--force(?:-with-lease)?",
            "message": "@:topics.git-foundations.git-foundations-module-3-manage-tracked-files.restore-without-rewriting-history.tryIt.try_restore_without_rewriting_history_sketch0.terminalExpectations.forbiddenCommands.0.message"
          }
        ]
      },
      "hiddenShellCheck": {
        "script": "set -eu\nrepo=release-kit\nfail() { printf \"%s\\n\" \"$1\" >&2; exit 1; }\ngit -C \"$repo\" rev-parse --is-inside-work-tree >/dev/null 2>&1 || fail \"The expected Git repository is missing.\"\n[ \"$(git -C \"$repo\" branch --show-current)\" = main ] || fail \"The repository is not on main.\"\n[ \"$(git -C \"$repo\" rev-list --count HEAD 2>/dev/null || printf 0)\" = 1 ] || fail \"The repository has the wrong number of commits.\"\n[ -z \"$(git -C \"$repo\" status --porcelain)\" ] || fail \"The working tree is not clean.\"\nexpected=$(printf \"%s\\n\" notes.txt | sort)\nactual=$(git -C \"$repo\" ls-files | sort)\n[ \"$actual\" = \"$expected\" ] || fail \"The tracked file set is not correct.\"\ngrep -Fxq \"Approved release note.\" \"$repo/notes.txt\"",
