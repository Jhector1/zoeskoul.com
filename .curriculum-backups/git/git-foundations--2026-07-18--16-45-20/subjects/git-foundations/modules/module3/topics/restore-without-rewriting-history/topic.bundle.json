          "path": "main.sh",
          "content": "cd release-kit\ngit restore notes.txt\ngit status --short\n",
          "language": "bash",
          "isEntry": true,
          "entry": true
        },
        {
          "path": ".zoeskoul/setup.sh",
          "content": "#!/usr/bin/env bash\nset -eu\nrm -rf release-kit\nmkdir -p release-kit\ngit -C release-kit init -q -b main\ngit -C release-kit config --local user.name \"ZoeSkoul Learner\"\ngit -C release-kit config --local user.email \"learner@zoeskoul.local\"\ncd release-kit\nprintf %s 'Approved release note.\n' > notes.txt\ncd ..\ngit -C release-kit add -A\ngit -C release-kit commit -q -m 'Add project baseline'\ncd release-kit\nprintf %s 'Accidental replacement.\n' > notes.txt\ncd ..\n",
          "language": "bash",
          "readOnly": true
        }
      ],
