        "solutionCode": "def calculate_expression(x, y, z):\n    return x + y * z\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nx = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\ny = _parse_arg(_inputs[1]) if len(_inputs) > 1 else \"\"\nz = _parse_arg(_inputs[2]) if len(_inputs) > 2 else \"\"\n\nprint(calculate_expression(x, y, z))"
      }
