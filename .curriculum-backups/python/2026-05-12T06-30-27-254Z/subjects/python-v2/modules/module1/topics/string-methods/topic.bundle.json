    {
      "id": "code-3",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-1.string-methods.quiz.code-3",
      "language": "python",
      "starterCode": "text = input()\n# Replace cat with dog and print the result",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "my cat is sleepy\n",
            "stdout": "my dog is sleepy\n",
            "match": "exact"
          },
          {
            "stdin": "cat cat\n",
            "stdout": "dog dog\n",
            "match": "exact"
          }
        ],
        "solutionCode": "text = input()\nprint(text.replace(\"cat\", \"dog\"))"
      }
    },
    {
      "id": "code-4",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-1.string-methods.quiz.code-4",
      "language": "python",
      "starterCode": "text = input()\nparts = text.split(\",\")\n# Print each part on its own line",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "red,blue,green\n",
            "stdout": "red\nblue\ngreen\n",
            "match": "exact"
          },
          {
            "stdin": "one,two,three\n",
            "stdout": "one\ntwo\nthree\n",
            "match": "exact"
          }
        ],
        "solutionCode": "text = input()\nparts = text.split(\",\")\nprint(parts[0])\nprint(parts[1])\nprint(parts[2])"
      }
    },
    {
      "id": "code-5",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-1.string-methods.quiz.code-5",
      "language": "python",
      "starterCode": "text = input()\n# Remove outside spaces\n# Split by commas\n# Join with \" | \" and print",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": " apple,banana,cherry \n",
            "stdout": "apple | banana | cherry\n",
            "match": "exact"
          },
          {
            "stdin": " red,blue \n",
            "stdout": "red | blue\n",
            "match": "exact"
          }
        ],
        "solutionCode": "text = input()\nclean = text.strip()\nparts = clean.split(\",\")\nresult = \" | \".join(parts)\nprint(result)"
      }
    }
