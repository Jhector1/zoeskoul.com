{
  "name": "@zoeskoul/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "i18n:generate": "node scripts/generate-i18n-manifest.mjs",
    "gen:topic-manifests": "tsx scripts/generate-topic-manifests.ts",
    "gen:subject-manifests": "tsx scripts/generate-subject-manifests.ts",
    "gen:catalog-manifests": "tsx scripts/generate-catalog-manifests.ts",
    "gen:manifests": "pnpm i18n:generate && pnpm gen:topic-manifests && pnpm gen:subject-manifests && pnpm gen:catalog-manifests",
    "audit:project-manifests": "tsx scripts/audit-project-manifest-bindings.ts",
    "audit:curriculum-project-integrity": "node scripts/audit-curriculum-project-manifest-integrity.mjs",
    "db:seed": "pnpm --dir ../.. --filter @zoeskoul/db db:seed",
    "sync:curriculum": "pnpm gen:manifests && pnpm db:seed",
    "predev": "pnpm gen:manifests",
    "prebuild": "pnpm gen:manifests",
    "pretypecheck": "pnpm gen:manifests",
    "pretest": "pnpm gen:manifests",
    "start": "next start --port 3000",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e:sql-review": "playwright test tests/e2e/sql-review --workers=1",
    "test:e2e": "pnpm test:e2e:stable",
    "test:e2e:review-practice": "playwright test tests/e2e/review-practice --workers=1",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:harness": "playwright test tests/e2e/harness",
    "test:e2e:manual": "playwright test tests/e2e/manual",
    "test:e2e:review-module-clone": "playwright test tests/e2e/review-module-clone  --workers=1",
    "test:e2e:real": "E2E_REAL_PROGRESS_API=1 E2E_REVIEW_URL=/en/catalog/python/subjects/python/modules/python-1/learn/python-1-core-building-blocks/variables-intro/exercise/boxes-print playwright test tests/e2e/review-code-workspace-real-api.spec.ts",
    "validate": "pnpm typecheck && pnpm test && pnpm build",
    "validate:e2e": "pnpm validate && pnpm test:e2e:harness   && pnpm test:e2e:practice-review && pnpm test:e2e:review-module-clone",
    "validate:full": "sh -c 'lsof -ti tcp:3000 | xargs kill -9 2>/dev/null || true; pnpm validate && pnpm test:e2e:stable'",
    "user:roles": "NODE_ENV=development tsx scripts/set-user-roles.ts",
    "postinstall": "prisma generate --schema ../../packages/db/prisma/schema.prisma",
    "cleanup:onboarding": "tsx scripts/cleanup-guest-onboarding.ts",
    "test:e2e:all:raw": "playwright test --workers=1",
    "validate:full:legacy": "lsof -ti tcp:3000 | xargs kill -9 && pnpm validate && pnpm test:e2e ",
    "test:e2e:stable": "playwright test --workers=1 tests/e2e/catalog-versioning/catalog-version-visibility.spec.ts tests/e2e/harness/e2e-sketch-save-harness.spec.ts tests/e2e/harness/review-progress-edge-cases.spec.ts tests/e2e/harness/review-progress-restore.spec.ts tests/e2e/review/curriculum-i18n-workspace-regression.spec.ts tests/e2e/review/reveal-fill-multifile.spec.ts tests/e2e/review/review-module-fill-answer-tools-sync.spec.ts tests/e2e/review/tools-editor-does-not-carry-stale-code.spec.ts tests/e2e/review/python-real-sum-list-route-navigation.spec.ts",
    "test:e2e:contracts": "playwright test --workers=1 tests/e2e/review/curriculum-i18n-workspace-regression.spec.ts",
    "test:e2e:runner": "RUNNER_E2E=1 playwright test --workers=1 tests/e2e/review/linux-terminal-session-reuse.spec.ts tests/e2e/review/linux-terminal-workspace-smoke.spec.ts tests/e2e/review/review-module-workspace-sync.spec.ts tests/e2e/review/curriculum-i18n-workspace-regression.spec.ts",
    "test:e2e:ide": "RUN_IDE_E2E=1 playwright test --workers=1 tests/e2e/full-ide-terminal-workspace-sync.spec.ts",
    "test:e2e:legacy": "RUN_E2E_LEGACY=1 playwright test --workers=1 tests/e2e/review/fill-answer-code-tool-pane.spec.ts tests/e2e/review/project-question-workspace-isolation.spec.ts tests/e2e/review/python-file-io-workspace-fixtures.spec.ts tests/e2e/review/python-project-exercise-route-navigation.spec.ts tests/e2e/review/reset-completion-regression.spec.ts tests/e2e/review/review-code-input-tools-workspace-persistence.spec.ts tests/e2e/review/review-dev-clone-project-back-forward-persistence.spec.ts tests/e2e/review/review-real-code-tools-back-forward-persistence.spec.ts tests/e2e/review/workspace-saved-beats-starter.spec.ts tests/e2e/review-module-clone/review-module-clone-hardening.spec.ts tests/e2e/review-module-clone/review-module-clone-navigation-workspace.spec.ts tests/e2e/review-module-clone/review-module-clone-production-safety.spec.ts",
    "test:e2e:all": "RUN_E2E_LEGACY=1 RUNNER_E2E=1 RUN_IDE_E2E=1 playwright test --workers=1"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@monaco-editor/react": "^4.7.0",
    "@next/env": "^16.2.1",
    "@prisma/client": "latest",
    "@tailwindcss/typography": "^0.5.19",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "@zoeskoul/code-contracts": "workspace:*",
    "@zoeskoul/curriculum-contracts": "workspace:*",
    "@zoeskoul/curriculum-profiles": "workspace:*",
    "@zoeskoul/curriculum-runtime": "workspace:*",
    "@zoeskoul/db": "workspace:*",
    "@zoeskoul/practice-checks": "workspace:*",
    "@zoeskoul/practice-contracts": "workspace:*",
    "@zoeskoul/pty-auth": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.34.0",
    "highlight.js": "^11.11.1",
    "image-size": "^2.0.2",
    "ioredis": "^5.11.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.27",
    "lucide-react": "^0.563.0",
    "monaco-editor": "^0.55.1",
    "next": "16.1.1",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.7.0",
    "next-themes": "^0.4.6",
    "p5": "^2.1.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "stripe": "^20.1.0",
    "tailwind-merge": "^3.4.0",
    "ws": "^8.20.0",
    "xterm": "^5.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/p5": "^1.7.7",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "8.11.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-katex": "^3.0.4",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "i": "^0.3.7",
    "npm": "^11.10.0",
    "pdfkit": "^0.17.2",
    "prisma": "latest",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
