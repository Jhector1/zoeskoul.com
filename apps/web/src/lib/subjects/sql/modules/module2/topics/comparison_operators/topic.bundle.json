              "rows": [
                [
                  1,
                  "Sketchbook",
                  "Art",
                  12.99,
                  25,
                  "2026-01-10"
                ],
                [
                  2,
                  "Acrylic Paint Set",
                  "Art",
                  24.5,
                  10,
                  "2026-02-02"
                ]
              ]
            },
            "match": "table_exact",
            "ignoreRowOrder": false
          }
        ]
