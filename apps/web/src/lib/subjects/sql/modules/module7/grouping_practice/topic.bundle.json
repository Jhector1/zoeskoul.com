      "language": "sql",
      "fixedSqlDialect": "sqlite",
      "recipe": {
        "type": "sql_query",
        "datasetId": "sales_kpi",
        "resultShape": "table",
        "solutionCode": "SELECT region, AVG(unit_price) AS avg_price\nFROM orders\nGROUP BY region\nHAVING AVG(unit_price) > 20;"
      }
