            "stdout": "The list is not empty.",
            "match": "exact"
          }
        ],
        "solutionCode": "def check_list(lst):\n    if lst:\n        return 'The list is not empty.'\n    else:\n        return 'The list is empty.'\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nlst = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(check_list(lst))"
      }
