          },
          {
            "stdin": "'Hello'",
            "stdout": "This value is truthy.",
            "match": "exact"
          },
          {
            "stdin": "0",
            "stdout": "This value is falsy.",
            "match": "exact"
          },
          {
            "stdin": "None",
            "stdout": "This value is falsy.",
            "match": "exact"
          }
        ],
        "solutionCode": "def check_truthiness(value):\n    if value:\n        return 'This value is truthy.'\n    else:\n        return 'This value is falsy.'\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nvalue = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(check_truthiness(value))"
      }
    },
