            "match": "exact"
          }
        ],
        "solutionCode": "def evaluate_truth(value):\n    if value:\n        return 'Truthy'\n    else:\n        return 'Falsy'\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nvalue = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(evaluate_truth(value))"
      }
