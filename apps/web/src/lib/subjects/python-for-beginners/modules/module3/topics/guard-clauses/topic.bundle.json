            "match": "exact"
          }
        ],
        "solutionCode": "def check_positive(number):\n    if number <= 0:\n        return 'Not a positive number'\n    return 'Positive number'\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nnumber = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(check_positive(number))"
      }
    },
