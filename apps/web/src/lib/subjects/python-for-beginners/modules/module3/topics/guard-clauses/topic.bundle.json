            "match": "exact"
          }
        ],
        "solutionCode": "def check_voting_age(age):\n    if age < 18:\n        return 'Too young to vote'\n    return 'Eligible to vote'\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nage = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(check_voting_age(age))"
      }
    },
