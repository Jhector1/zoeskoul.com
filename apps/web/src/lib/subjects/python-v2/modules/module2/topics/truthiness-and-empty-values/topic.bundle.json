      "language": "python",
      "starterCode": "def evaluate_value(value):\n    # Determine if value is truthy or falsy\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nvalue = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(evaluate_value(value))",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "12\n",
            "stdout": "Truthy",
            "match": "exact"
          },
          {
            "stdin": "20\n",
            "stdout": "Truthy",
            "match": "exact"
          }
        ],
        "solutionCode": "def evaluate_value(value):\n    return 'Truthy' if value else 'Falsy'\n\n# Test the function\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nvalue = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\n\nprint(evaluate_value(value))"
      }
    },
