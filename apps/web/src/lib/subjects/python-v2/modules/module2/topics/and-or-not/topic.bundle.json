      "language": "python",
      "starterCode": "def check_discount(is_member, amount_spent):\n    # Check eligibility\n    pass\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nis_member = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\namount_spent = _parse_arg(_inputs[1]) if len(_inputs) > 1 else \"\"\n\nprint(check_discount(is_member, amount_spent))",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "True, 50\n1\n",
            "stdout": "True",
            "match": "exact"
          },
          {
            "stdin": "False, 150\n1\n",
            "stdout": "True",
            "match": "exact"
          },
          {
            "stdin": "False, 50\n1\n",
            "stdout": "True",
            "match": "exact"
          }
        ],
        "solutionCode": "def check_discount(is_member, amount_spent):\n    if is_member or amount_spent > 100:\n        return True\n    return False\n\nimport ast\n\ndef _parse_arg(raw):\n    try:\n        return ast.literal_eval(raw)\n    except Exception:\n        return raw\n\n_inputs = []\ntry:\n    while True:\n        _inputs.append(input())\nexcept EOFError:\n    pass\nis_member = _parse_arg(_inputs[0]) if len(_inputs) > 0 else \"\"\namount_spent = _parse_arg(_inputs[1]) if len(_inputs) > 1 else \"\"\n\nprint(check_discount(is_member, amount_spent))"
      }
    },
