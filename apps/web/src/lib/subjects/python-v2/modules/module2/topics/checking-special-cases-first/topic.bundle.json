      "starterCode": "age = int(input())\n\n# TODO: print Invalid, Child, or Older",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "-3\n",
            "stdout": "Invalid\n",
            "match": "exact"
          },
          {
            "stdin": "8\n",
            "stdout": "Child\n",
            "match": "exact"
          },
          {
            "stdin": "20\n",
            "stdout": "Older\n",
            "match": "exact"
          }
        ],
        "solutionCode": "age = int(input())\n\nif age < 0:\n    print(\"Invalid\")\nelif age < 13:\n    print(\"Child\")\nelse:\n    print(\"Older\")"
      }
    },
