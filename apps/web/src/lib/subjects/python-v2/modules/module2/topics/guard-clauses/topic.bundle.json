          },
          {
            "stdin": "8\n",
            "stdout": "Accepted\n",
            "match": "exact"
          }
        ],
        "solutionCode": "number = int(input())\n\nif number <= 0:\n    print(\"Not positive\")\nelif number % 2 != 0:\n    print(\"Not even\")\nelse:\n    print(\"Accepted\")"
