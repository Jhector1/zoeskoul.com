      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-2.guard-clauses.quiz.guard-membership-checker",
      "language": "python",
      "starterCode": "age = int(input())\nmembership = input().strip()\n\n# Write your code below",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "-1\nyes\n",
            "stdout": "Invalid age\n",
            "match": "exact"
          },
          {
            "stdin": "20\nno\n",
            "stdout": "Members only\n",
            "match": "exact"
          },
          {
            "stdin": "17\nyes\n",
            "stdout": "Too young\n",
            "match": "exact"
          },
          {
            "stdin": "22\nyes\n",
            "stdout": "Access granted\n",
            "match": "exact"
          }
        ],
        "solutionCode": "age = int(input())\nmembership = input().strip()\n\nif age < 0:\n    print(\"Invalid age\")\nelif membership != \"yes\":\n    print(\"Members only\")\nelif age >= 18:\n    print(\"Access granted\")\nelse:\n    print(\"Too young\")"
      }
    },
