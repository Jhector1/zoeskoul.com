          {
            "stdin": "education\n",
            "stdout": "5\n",
            "match": "exact"
          }
        ],
        "solutionCode": "text = input()\ncount = 0\nfor ch in text:\n    if ch in \"aeiou\":\n        count += 1\nprint(count)"
