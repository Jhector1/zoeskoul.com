      "starterCode": "count = 0\nwhile count <= 10:\n    # Add your code here\n    count += 1",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "12\n",
            "stdout": "1\n3\n5\n7\n9",
            "match": "exact"
          },
          {
            "stdin": "20\n",
            "stdout": "1\n3\n5\n7\n9",
            "match": "exact"
          }
        ],
        "solutionCode": "count = 0\nwhile count <= 10:\n    if count % 2 != 0:\n        print(count)\n    count += 1"
      }
