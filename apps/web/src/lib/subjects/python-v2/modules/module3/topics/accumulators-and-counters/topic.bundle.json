      "starterCode": "parts = input().split()\ntotal = 0\n\n# TODO: loop through parts, add each number to total\n\nprint(total)",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "3 5 2\n",
            "stdout": "10\n",
            "match": "exact"
          },
          {
            "stdin": "10 0 -4 7\n",
            "stdout": "13\n",
            "match": "exact"
          }
        ],
        "solutionCode": "parts = input().split()\ntotal = 0\n\nfor part in parts:\n    total = total + int(part)\n\nprint(total)"
      }
    },
    {
      "id": "ex10",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.accumulators-and-counters.quiz.ex10",
      "language": "python",
      "starterCode": "word = input()\nvowel_count = 0\n\n# TODO: loop through the characters in word\n# TODO: if the character is a vowel, increase vowel_count\n\nprint(vowel_count)",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "banana\n",
            "stdout": "3\n",
            "match": "exact"
          },
          {
            "stdin": "sky\n",
            "stdout": "0\n",
            "match": "exact"
          }
        ],
        "solutionCode": "word = input()\nvowel_count = 0\n\nfor ch in word:\n    if ch in \"aeiou\":\n        vowel_count = vowel_count + 1\n\nprint(vowel_count)"
      }
    },
    {
      "id": "ex11",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.accumulators-and-counters.quiz.ex11",
      "language": "python",
      "starterCode": "parts = input().split()\neven_total = 0\n\n# TODO: loop through the parts\n# TODO: convert each part to an integer\n# TODO: if the number is even, add it to even_total\n\nprint(even_total)",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "4 7 2 9 6\n",
            "stdout": "12\n",
            "match": "exact"
          },
          {
            "stdin": "1 3 5 8\n",
            "stdout": "8\n",
            "match": "exact"
          }
        ],
        "solutionCode": "parts = input().split()\neven_total = 0\n\nfor part in parts:\n    n = int(part)\n    if n % 2 == 0:\n        even_total = even_total + n\n\nprint(even_total)"
      }
    },
    {
      "id": "ex12",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-v2-3.accumulators-and-counters.quiz.ex12",
      "language": "python",
      "starterCode": "parts = input().split()\ncount = 0\n\n# TODO: loop through the parts\n# TODO: count numbers greater than 0\n\nprint(count)",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "-2 5 0 3 -1\n",
            "stdout": "2\n",
            "match": "exact"
          },
          {
            "stdin": "1 2 3 4\n",
            "stdout": "4\n",
            "match": "exact"
          }
        ],
        "solutionCode": "parts = input().split()\ncount = 0\n\nfor part in parts:\n    n = int(part)\n    if n > 0:\n        count = count + 1\n\nprint(count)"
      }
    },
