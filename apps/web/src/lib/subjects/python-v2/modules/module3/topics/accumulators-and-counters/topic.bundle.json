      "starterCode": "line = input()\n# Write Python code that prints the sum of the numbers.",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "3 5 2\n",
            "stdout": "10\n",
            "match": "exact"
          },
          {
            "stdin": "10 1 4 7\n",
            "stdout": "22\n",
            "match": "exact"
          },
          {
            "stdin": "8\n",
            "stdout": "8\n",
            "match": "exact"
          }
        ],
        "solutionCode": "line = input()\nparts = line.split()\ntotal = 0\n\nfor part in parts:\n    total = total + int(part)\n\nprint(total)"
      }
    },
    {
      "id": "code-count-positive",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "topics.python-v2.python-3.accumulators-and-counters.quiz.code-count-positive",
      "language": "python",
      "starterCode": "line = input()\n# Write Python code that prints how many numbers are greater than 0.",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "-2 5 0 3 -1\n",
            "stdout": "2\n",
            "match": "exact"
          },
          {
            "stdin": "1 2 3 4\n",
            "stdout": "4\n",
            "match": "exact"
          },
          {
            "stdin": "-5 0 -1\n",
            "stdout": "0\n",
            "match": "exact"
          }
        ],
        "solutionCode": "line = input()\nparts = line.split()\ncount = 0\n\nfor part in parts:\n    number = int(part)\n    if number > 0:\n        count = count + 1\n\nprint(count)"
      }
    }
  ]
