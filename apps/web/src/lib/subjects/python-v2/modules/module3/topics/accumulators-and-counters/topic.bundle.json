      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "code\n",
            "stdout": "c-o-d-e-\n",
            "match": "exact"
          },
          {
            "stdin": "hi\n",
            "stdout": "h-i-\n",
            "match": "exact"
          }
        ],
        "solutionCode": "word = input()\nresult = \"\"\n\nfor ch in word:\n    result = result + ch + \"-\"\n\nprint(result)"
