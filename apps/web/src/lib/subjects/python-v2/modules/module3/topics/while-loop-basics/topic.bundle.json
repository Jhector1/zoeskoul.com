      "language": "python",
      "starterCode": "count = 1\n\n# Use a while loop to print 1 through 4.",
      "showExpectedExample": true,
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "",
            "stdout": "1\n2\n3\n4\n",
            "match": "exact"
          }
        ],
        "solutionCode": "count = 1\nwhile count <= 4:\n    print(count)\n    count = count + 1"
      }
    },
