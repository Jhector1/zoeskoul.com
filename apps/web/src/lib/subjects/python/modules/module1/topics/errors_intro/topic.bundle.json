          },
          {
            "stdin": "twelve\n",
            "stdout": "Invalid age\n",
            "match": "exact"
          }
        ],
        "solutionCode": "text = input().strip()\nif text.isdigit():\n    age = int(text)\n    print(f\"Next year = {age + 1}\")\nelse:\n    print(\"Invalid age\")\n"
