  "exercises": [
    {
      "id": "m1_io_age_next_year",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m1_io_age_next_year",
      "language": "python",
      "recipe": {
        "type": "template_io",
        "vars": {
          "name": {
            "source": "pick",
            "from": ["Maya", "Jordan", "Alex", "Sam"]
          },
          "age": {
            "source": "int",
            "min": 10,
            "max": 40
          }
        },
        "computed": {
          "age_next": {
            "op": "add",
            "left": "age",
            "right": 1
          }
        },
        "tests": [
          {
            "stdinTemplate": "{name}\n{age}\n",
            "stdoutTemplate": "Hi {name}! Next year you'll be {age_next}.\n",
            "match": "exact"
          }
        ],
        "solutionTemplate": "name = input()\nage = int(input())\nprint(f\"Hi {name}! Next year you'll be {age + 1}.\")\n"
      }
    },
    {
      "id": "m1_io_tip_total",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m1_io_tip_total",
      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "40\n15\n",
            "stdout": "Tip = 6\nTotal = 46\n",
            "match": "exact"
          },
          {
            "stdin": "25\n20\n",
            "stdout": "Tip = 5\nTotal = 30\n",
            "match": "exact"
          }
        ],
        "solutionCode": "bill = int(input())\npct = int(input())\ntip = bill * pct // 100\ntotal = bill + tip\nprint(f\"Tip = {tip}\")\nprint(f\"Total = {total}\")\n"
      }
    },
    {
      "id": "m1_io_c_to_f",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m1_io_c_to_f",
      "language": "python",
      "recipe": {
        "type": "template_io",
        "vars": {
          "c": {
            "source": "int",
            "min": -10,
            "max": 35
          }
        },
        "computed": {
          "f": {
            "op": "c_to_f_int",
            "left": "c"
          }
        },
        "tests": [
          {
            "stdinTemplate": "{c}\n",
            "stdoutTemplate": "{f}\n",
            "match": "exact"
          }
        ],
        "solutionTemplate": "c = int(input())\nf = int(c * 9 / 5 + 32)\nprint(f)\n"
      }
    },

