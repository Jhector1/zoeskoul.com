  "exercises": [
    {
      "id": "m1_io_age_next_year",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m1_io_age_next_year",
      "language": "python",
      "showExpectedExample": true,

      "workspace": {
        "entryFile": "main.py",
        "initialStdin": "Maya\n18\n",
        "starterFiles": {
          "main.py": "name = input()\nage = int(input())\n\n# TODO: compute age next year\nage_next = age\n\n# TODO: print the final message\nprint(f\"Hi {name}! Next year you'll be {age_next}.\")\n",
          "README.md": "Goal:\n\nRead a name and an age.\nPrint the age the person will be next year.\n\nExample input:\nMaya\n18\n\nExample output:\nHi Maya! Next year you'll be 19.\n"
        }
      },

      "recipe": {
        "type": "template_io",
        "vars": {
          "name": {
            "source": "pick",
            "from": ["Maya", "Jordan", "Alex", "Sam"]
          },
          "age": {
            "source": "int",
            "min": 10,
            "max": 40
          }
        },
        "computed": {
          "age_next": {
            "op": "add",
            "left": "age",
            "right": 1
          }
        },
        "tests": [
          {
            "stdinTemplate": "{name}\n{age}\n",
            "stdoutTemplate": "Hi {name}! Next year you'll be {age_next}.\n",
            "match": "exact"
          }
        ],
        "solutionTemplate": "name = input()\nage = int(input())\nprint(f\"Hi {name}! Next year you'll be {age + 1}.\")\n"
      }
    },
    {
      "id": "m1_io_tip_total",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m1_io_tip_total",
      "language": "python",
      "showExpectedExample": true,

      "workspace": {
        "entryFile": "main.py",
        "initialStdin": "40\n15\n",
        "starterFiles": {
          "main.py": "bill = int(input())\npct = int(input())\n\n# TODO: calculate the tip using integer math\n# Example: bill 40 and pct 15 should give tip 6\ntip = 0\n\n# TODO: calculate the total\ntotal = 0\n\nprint(f\"Tip = {tip}\")\nprint(f\"Total = {total}\")\n",
          "helper_notes.md": "Use integer division for this beginner exercise:\n\ntip = bill * pct // 100\n\ntotal = bill + tip\n"
        }
      },

      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "40\n15\n",
            "stdout": "Tip = 6\nTotal = 46\n",
            "match": "exact"
          },
          {
            "stdin": "25\n20\n",
            "stdout": "Tip = 5\nTotal = 30\n",
            "match": "exact"
          }
        ],
        "solutionCode": "bill = int(input())\npct = int(input())\ntip = bill * pct // 100\ntotal = bill + tip\nprint(f\"Tip = {tip}\")\nprint(f\"Total = {total}\")\n"
      }
    },
    {
      "id": "m1_io_c_to_f",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m1_io_c_to_f",
      "language": "python",

      "workspace": {
        "entryFile": "main.py",
        "initialStdin": "10\n",
        "starterFiles": {
          "main.py": "c = int(input())\n\n# TODO: convert Celsius to Fahrenheit\nf = 0\n\nprint(f)\n",
          "formula.md": "Use this formula:\n\nf = int(c * 9 / 5 + 32)\n\nThe int() keeps the result as a whole number for this exercise.\n"
        }
      },

      "recipe": {
        "type": "template_io",
        "vars": {
          "c": {
            "source": "int",
            "min": -10,
            "max": 35
          }
        },
        "computed": {
          "f": {
            "op": "c_to_f_int",
            "left": "c"
          }
        },
        "tests": [
          {
            "stdinTemplate": "{c}\n",
            "stdoutTemplate": "{f}\n",
            "match": "exact"
          }
        ],
        "solutionTemplate": "c = int(input())\nf = int(c * 9 / 5 + 32)\nprint(f)\n"
      }
    },

