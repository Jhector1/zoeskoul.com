      "workspace": {
        "entryFile": "main.py",
        "initialStdin": "",
        "starterFiles": {
          "main.py": "# Input → Convert → Compute → Show\n\nname = input(\"Name: \")\nage_text = input(\"Age: \")\n\nage = int(age_text)\nnext_age = age + 1\n\nprint(f\"Hi {name}! Next year you'll be {next_age}.\")\n",
          "README.md": "This sketch shows the main beginner Python input/output pattern:\n\n1. Get input with input()\n2. Convert text when needed\n3. Compute a result\n4. Show the result with print()\n"
        }
