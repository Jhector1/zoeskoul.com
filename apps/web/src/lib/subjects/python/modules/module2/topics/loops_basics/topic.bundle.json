      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m2_loop_echo_until_quit_code",
      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "hello\nabc\nquit\n",
            "stdout": "You typed: hello\nYou typed: abc\nBye!\n",
            "match": "exact"
          }
        ],
        "solutionCode": "cmd = input().strip()\nwhile cmd != \"quit\":\n    print(f\"You typed: {cmd}\")\n    cmd = input().strip()\nprint(\"Bye!\")\n"
      },
      "starterCode": "cmd = input().strip()\n# TODO: loop until cmd == \"quit\"\n# TODO: echo each non-quit command"
