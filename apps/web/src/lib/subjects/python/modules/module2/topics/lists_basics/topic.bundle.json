      "id": "m2_list_three_prices_sum_avg_code",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m2_list_three_prices_sum_avg_code",
      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          {
            "stdin": "10\n20\n30\n",
            "stdout": "sum = 60\navg = 20\n",
            "match": "exact"
          }
        ],
        "solutionCode": "a = int(input())\nb = int(input())\nc = int(input())\nprices = [a, b, c]\ntotal = sum(prices)\navg = total // 3\nprint(f\"sum = {total}\")\nprint(f\"avg = {avg}\")\n"
      }
    },
