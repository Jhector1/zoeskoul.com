    {
      "id": "m2_func_total_with_tip_code",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m2_func_total_with_tip_code",
      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          { "stdin": "40\n15\n", "stdout": "Total = 46\n", "match": "exact" },
          { "stdin": "25\n20\n", "stdout": "Total = 30\n", "match": "exact" }
        ],
        "solutionCode": "def total_with_tip(bill, pct):\n    tip = bill * pct // 100\n    return bill + tip\n\nbill = int(input())\npct = int(input())\ntotal = total_with_tip(bill, pct)\nprint(f\"Total = {total}\")\n"
      }
    },
    {
      "id": "m2_func_shipping_rule_code",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m2_func_shipping_rule_code",
      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          { "stdin": "60\n", "stdout": "Shipping = 0\n", "match": "exact" },
          { "stdin": "40\n", "stdout": "Shipping = 7\n", "match": "exact" }
        ],
        "solutionCode": "def shipping_cost(total):\n    if total >= 50:\n        return 0\n    else:\n        return 7\n\ntotal = int(input())\nprint(f\"Shipping = {shipping_cost(total)}\")\n"
      }
    },
    {
      "id": "m2_func_sum_list_code",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m2_func_sum_list_code",
      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          { "stdin": "3\n4\n5\n", "stdout": "sum = 12\n", "match": "exact" },
          { "stdin": "10\n20\n30\n", "stdout": "sum = 60\n", "match": "exact" }
        ],
        "solutionCode": "def sum_list(xs):\n    total = 0\n    for x in xs:\n        total = total + x\n    return total\n\na = int(input())\nb = int(input())\nc = int(input())\nxs = [a, b, c]\nprint(f\"sum = {sum_list(xs)}\")\n"
      }
