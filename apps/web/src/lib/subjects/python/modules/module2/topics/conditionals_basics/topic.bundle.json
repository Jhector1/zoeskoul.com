    {
      "id": "m2_cond_member_discount_code",
      "kind": "code_input",
      "purpose": "project",
      "weight": 1,
      "messageBase": "quiz.m2_cond_member_discount_code",
      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          { "stdin": "100\ny\n", "stdout": "Total = 90\n", "match": "exact" },
          { "stdin": "100\nY\n", "stdout": "Total = 90\n", "match": "exact" },
          { "stdin": "100\nn\n", "stdout": "Total = 100\n", "match": "exact" }
        ],
        "solutionCode": "subtotal = int(input())\nmember = input().strip()\nif member.lower() == \"y\":\n    discount = subtotal * 10 // 100\n    total = subtotal - discount\nelse:\n    total = subtotal\nprint(f\"Total = {total}\")\n"
      }
    },
