      "language": "python",
      "recipe": {
        "type": "fixed_tests",
        "tests": [
          { "stdin": "18\n", "stdout": "ALLOWED\n", "match": "exact" },
          { "stdin": "17\n", "stdout": "DENIED\n", "match": "exact" }
